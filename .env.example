# Supabase project settings — see https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, never expose to the client. Used for
# invite redemption, account provisioning, and signal calculation.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# "production" hides the "development version" disclaimer banner.
NEXT_PUBLIC_APP_ENV=development
